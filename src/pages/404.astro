---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Сторінку не знайдено - Юрист На Плаву">
  <Header />
  <main>
    <section class="min-h-[60vh] flex items-center justify-center py-20 md:py-32 bg-gradient-to-b from-primary-50 to-white dark:from-primary-950 dark:to-gray-900">
      <div class="container-custom text-center">
        <h1 class="text-8xl md:text-9xl font-bold text-accent-500 mb-6">404</h1>
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white mb-4">
          Сторінку не знайдено
        </h2>
        <p class="text-lg text-gray-600 dark:text-gray-400 mb-8 max-w-md mx-auto">
          На жаль, сторінка, яку Ви шукаєте, не існує або була переміщена.
        </p>
        <a href="/" class="btn-primary text-base px-6 py-3">
          Повернутися на головну
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
          </svg>
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

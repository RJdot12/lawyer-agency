---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

// Get specific cases by order number (1, 2, 5, 10)
const allCases = await getCollection('cases');
const featuredOrders = [1, 2, 5, 10];
const featuredCases = featuredOrders
  .map(order => allCases.find(c => c.data.order === order))
  .filter(Boolean);
---

<section id="featured-cases" class="section bg-white dark:bg-gray-800">
  <div class="container-custom">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="mb-6 text-gray-900 dark:text-white">Наша практика</h2>
      <p class="text-gray-600 dark:text-gray-300">
        Кожен кейс — це унікальна історія успіху людей, які нам довірилися.
      </p>
    </div>

    <!-- Cases Grid -->
    <div class="grid md:grid-cols-2 gap-6 lg:gap-8">
      {featuredCases.map((caseEntry, index) => (
        <article
          class="case-card group"
          data-animate="fade-in-up"
          data-delay={index * 100}
        >
          <!-- Image Container -->
          <div class="case-image-container">
            <Image
              src={caseEntry.data.image}
              alt={caseEntry.data.imageAlt || caseEntry.data.title}
              class="case-image"
              loading="lazy"
              format="webp"
            />
            <!-- Category Badge -->
            <span class="case-category">
              {caseEntry.data.category}
            </span>
            <!-- Overlay on hover -->
            <div class="case-overlay">
              <a
                href={`/cases/${caseEntry.id.replace('.md', '')}`}
                class="case-view-btn"
              >
                Детальніше
                <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                </svg>
              </a>
            </div>
          </div>

          <!-- Content -->
          <div class="case-content">
            <h3 class="case-title">
              <a href={`/cases/${caseEntry.id.replace('.md', '')}`}>
                {caseEntry.data.title}
              </a>
            </h3>
            <p class="case-brief">
              {caseEntry.data.brief}
            </p>

            <!-- Result indicator -->
            <div class="case-result">
              <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span>Успішно вирішено</span>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- CTA to view all cases -->
    <div class="mt-12 text-center">
      <a href="/case-study" class="btn-primary">
        Переглянути всі кейси
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .case-card {
    background: linear-gradient(to bottom right, rgba(255, 255, 255, 0.98), rgba(249, 250, 251, 0.98));
    border: 2px solid var(--color-gray-100);
    border-radius: 1rem;
    overflow: hidden;
    transition: all 0.3s ease;
  }

  :global(.dark) .case-card {
    background: var(--color-secondary-900);
    border-color: var(--color-gray-700);
  }

  /* Mobile: no transform, just subtle border change on active */
  @media (max-width: 767px) {
    .case-card:active {
      border-color: var(--color-accent-400);
    }

    :global(.dark) .case-card:active {
      border-color: var(--color-accent-500);
    }
  }

  /* Desktop: full hover effects */
  @media (min-width: 768px) {
    .case-card:hover {
      border-color: var(--color-accent-400);
      transform: translateY(-6px);
      box-shadow: 0 20px 40px -10px rgba(0, 0, 0, 0.15);
    }

    :global(.dark) .case-card:hover {
      border-color: var(--color-accent-500);
      box-shadow: 0 20px 40px -10px rgba(0, 0, 0, 0.4);
    }
  }

  .case-image-container {
    position: relative;
    height: 200px;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .case-image-container {
      height: 240px;
    }
  }

  .case-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  /* Desktop only: image zoom on hover */
  @media (min-width: 768px) {
    .case-card:hover .case-image {
      transform: scale(1.08);
    }
  }

  .case-category {
    position: absolute;
    top: 1rem;
    left: 1rem;
    padding: 0.375rem 0.875rem;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(4px);
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-accent-700);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  :global(.dark) .case-category {
    background: rgba(54, 57, 63, 0.95);
    color: var(--color-accent-300);
  }

  .case-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.7), transparent 60%);
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding-bottom: 1.5rem;
    /* Mobile: always visible */
    opacity: 1;
  }

  /* Desktop: hide overlay by default, show on hover */
  @media (min-width: 768px) {
    .case-overlay {
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .case-card:hover .case-overlay {
      opacity: 1;
    }
  }

  .case-view-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.625rem 1.25rem;
    background: white;
    color: var(--color-primary-600);
    font-weight: 600;
    font-size: 0.875rem;
    border-radius: 0.5rem;
    /* Mobile: no transform, already visible */
    transform: translateY(0);
    transition: all 0.3s ease;
  }

  /* Desktop: animate button on hover */
  @media (min-width: 768px) {
    .case-view-btn {
      transform: translateY(10px);
    }

    .case-card:hover .case-view-btn {
      transform: translateY(0);
    }
  }

  .case-view-btn:hover {
    background: var(--color-accent-500);
    color: white;
  }

  /* Mobile: active state for button */
  @media (max-width: 767px) {
    .case-view-btn:active {
      background: var(--color-accent-500);
      color: white;
    }
  }

  .case-content {
    padding: 1.5rem;
  }

  .case-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-gray-900);
    margin-bottom: 0.75rem;
    line-height: 1.4;
  }

  :global(.dark) .case-title {
    color: white;
  }

  .case-title a {
    transition: color 0.2s ease;
  }

  .case-title a:hover {
    color: var(--color-accent-500);
  }

  .case-brief {
    font-size: 0.9375rem;
    color: var(--color-gray-600);
    line-height: 1.6;
    margin-bottom: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  :global(.dark) .case-brief {
    color: var(--color-gray-400);
  }

  .case-result {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-green-600);
  }

  :global(.dark) .case-result {
    color: var(--color-green-400);
  }
</style>
